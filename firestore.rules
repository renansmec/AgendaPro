rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to check if user is a member of the workspace
    function isWorkspaceMember(workspaceId) {
      return exists(/databases/$(database)/documents/workspaceMembers/$(workspaceId + '_' + request.auth.uid));
    }
    
    match /workspaces/{workspaceId} {
      allow read: if isWorkspaceMember(workspaceId);
      allow create: if request.auth != null;
    }
    
    match /workspaceMembers/{memberId} {
      allow read, write: if request.auth != null;
    }
    
    match /workspaceInvites/{inviteId} {
      allow read, write: if request.auth != null;
    }

    match /tasks/{taskId} {
      allow read, write: if request.auth != null && isWorkspaceMember(resource.data.workspaceId);
      allow create: if request.auth != null && isWorkspaceMember(request.resource.data.workspaceId);
    }
    
    match /projects/{projectId} {
      allow read, write: if request.auth != null && isWorkspaceMember(resource.data.workspaceId);
      allow create: if request.auth != null && isWorkspaceMember(request.resource.data.workspaceId);
    }
    
    match /projectTemplates/{templateId} {
      allow read, write: if request.auth != null && isWorkspaceMember(resource.data.workspaceId);
      allow create: if request.auth != null && isWorkspaceMember(request.resource.data.workspaceId);
    }
  }
}
